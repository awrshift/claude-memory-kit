{
  "$meta": {
    "name": "SaaS Dark",
    "version": "1.0.0",
    "theme": "dark",
    "generator": "/design init",
    "description": "Professional dark theme for data-driven SaaS applications"
  },
  "color": {
    "$type": "color",
    "core": {
      "cyan-500":  { "value": "#06b6d4", "description": "Electric Cyan" },
      "cyan-600":  { "value": "#0891b2", "description": "Deep Cyan" },
      "navy-900":  { "value": "#0c1222", "description": "Deep Navy" },
      "navy-800":  { "value": "#1e293b", "description": "Slate Card" },
      "slate-700": { "value": "#334155", "description": "Subtle Border" },
      "slate-400": { "value": "#94a3b8", "description": "Cool Gray" },
      "white-95":  { "value": "#f8fafc", "description": "Clean White" },
      "red-500":   { "value": "#ef4444", "description": "Alert Red" },
      "green-500": { "value": "#22c55e", "description": "Success Green" },
      "amber-500": { "value": "#f59e0b", "description": "Warning Amber" }
    },
    "semantic": {
      "primary":        { "value": "{color.core.cyan-500}", "description": "CTAs, active states, links" },
      "primary-hover":  { "value": "{color.core.cyan-600}", "description": "CTA hover state" },
      "background":     { "value": "{color.core.navy-900}", "description": "Page and section backgrounds" },
      "surface":        { "value": "{color.core.navy-800}", "description": "Cards, panels, sidebars" },
      "border":         { "value": "{color.core.slate-700}", "description": "1px borders on cards" },
      "text-primary":   { "value": "{color.core.white-95}", "description": "Headlines, labels" },
      "text-secondary": { "value": "{color.core.slate-400}", "description": "Body text, descriptions" },
      "error":          { "value": "{color.core.red-500}", "description": "Error states, destructive actions" },
      "success":        { "value": "{color.core.green-500}", "description": "Success states, positive indicators" },
      "warning":        { "value": "{color.core.amber-500}", "description": "Warning states, attention needed" }
    }
  },
  "typography": {
    "font-primary": { "value": "DM Sans", "description": "Clean and modern, all weights" },
    "font-mono":    { "value": "JetBrains Mono", "description": "Code blocks, metrics, data tables" },
    "scale": {
      "$type": "dimension",
      "xs":   { "value": "12px", "description": "Captions, metadata" },
      "sm":   { "value": "14px", "description": "Secondary text, table cells" },
      "base": { "value": "16px", "description": "Body text" },
      "lg":   { "value": "18px", "description": "Subtitles" },
      "xl":   { "value": "20px", "description": "Section titles" },
      "2xl":  { "value": "24px", "description": "Page titles" },
      "3xl":  { "value": "30px", "description": "Hero text" },
      "4xl":  { "value": "36px", "description": "Display text" }
    }
  },
  "spacing": {
    "$type": "dimension",
    "unit":      { "value": "4px", "description": "Base spacing unit (multiply: 2=8px, 3=12px, 4=16px)" },
    "max-width": { "value": "1440px", "description": "Content max-width" },
    "grid-gap":  { "value": "24px", "description": "Default grid gap" },
    "section-y": { "value": "64px", "description": "Vertical spacing between sections" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "value": "4px", "description": "Inputs, badges" },
    "md": { "value": "8px", "description": "Buttons, small cards" },
    "lg": { "value": "12px", "description": "Cards, panels" },
    "xl": { "value": "16px", "description": "Modals, large containers" }
  }
}
