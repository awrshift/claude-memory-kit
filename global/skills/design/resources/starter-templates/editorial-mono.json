{
  "$meta": {
    "name": "Editorial Mono",
    "version": "1.0.0",
    "theme": "light",
    "generator": "/design init",
    "description": "Monochrome editorial theme with strong typography"
  },
  "color": {
    "$type": "color",
    "core": {
      "black":    { "value": "#0a0a0a", "description": "True Black" },
      "charcoal": { "value": "#262626", "description": "Dark Charcoal" },
      "gray-500": { "value": "#737373", "description": "Medium Gray" },
      "gray-300": { "value": "#d4d4d4", "description": "Light Gray" },
      "gray-100": { "value": "#f5f5f5", "description": "Near White" },
      "white":    { "value": "#fafafa", "description": "Paper White" },
      "red-600":  { "value": "#dc2626", "description": "Editorial Red" }
    },
    "semantic": {
      "primary":        { "value": "{color.core.black}",    "description": "Headlines, CTAs" },
      "primary-hover":  { "value": "{color.core.charcoal}", "description": "Hover state" },
      "background":     { "value": "{color.core.white}",    "description": "Page background" },
      "surface":        { "value": "{color.core.gray-100}", "description": "Card backgrounds" },
      "border":         { "value": "{color.core.gray-300}", "description": "Borders, dividers" },
      "text-primary":   { "value": "{color.core.black}",    "description": "Body text" },
      "text-secondary": { "value": "{color.core.gray-500}", "description": "Captions, metadata" },
      "accent":         { "value": "{color.core.red-600}",  "description": "Accent for emphasis, links" }
    }
  },
  "typography": {
    "font-primary": { "value": "Playfair Display", "description": "Classic serif for headlines" },
    "font-body":    { "value": "Source Serif 4",   "description": "Readable serif for body text" },
    "font-mono":    { "value": "IBM Plex Mono",    "description": "Monospace for code, metadata" },
    "scale": {
      "$type": "dimension",
      "xs":   { "value": "11px" },
      "sm":   { "value": "13px" },
      "base": { "value": "17px", "description": "Comfortable reading size" },
      "lg":   { "value": "20px" },
      "xl":   { "value": "24px" },
      "2xl":  { "value": "32px" },
      "3xl":  { "value": "40px" },
      "4xl":  { "value": "48px" },
      "5xl":  { "value": "64px", "description": "Display" }
    }
  },
  "spacing": {
    "$type": "dimension",
    "unit":      { "value": "4px" },
    "max-width": { "value": "720px", "description": "Narrow reading column" },
    "grid-gap":  { "value": "24px" },
    "section-y": { "value": "80px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "value": "2px" },
    "md": { "value": "4px" },
    "lg": { "value": "8px" }
  }
}
