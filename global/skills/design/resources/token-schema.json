{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Design Tokens",
  "description": "Schema for design-tokens.json used by /design skill",
  "type": "object",
  "required": ["$meta"],
  "properties": {
    "$meta": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name":        { "type": "string" },
        "version":     { "type": "string" },
        "theme":       { "type": "string" },
        "generator":   { "type": "string" },
        "description": { "type": "string" }
      }
    }
  },
  "additionalProperties": {
    "type": "object",
    "description": "Token category (color, typography, spacing, radius, etc.)"
  }
}
